# Copy to .env.local for local dev, or .env.prod for production testing.
# Never commit files with real secrets.

# --- Local (.env.local) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mergefruit
DB_USER=mergefruit
DB_PASSWORD=change-me
DB_URL=postgresql://mergefruit:change-me@localhost:5432/mergefruit

JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ANONYMOUS_USER_PASSWORD=change-me-internal
CORS_ALLOWED_ORIGINS=http://localhost:5173

